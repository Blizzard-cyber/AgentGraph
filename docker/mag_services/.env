# MemMachine Docker Compose Environment Configuration
# Copy this file to .env and update the values according to your setup

# =============================================================================
# PostgreSQL/pgvector Database Configuration
# =============================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=memmachine
POSTGRES_PASSWORD=memmachine_password
POSTGRES_DB=memmachine

# =============================================================================
# Neo4j Database Configuration
# =============================================================================
NEO4J_HOST=neo4j
NEO4J_PORT=7697
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password
NEO4J_HTTP_PORT=7484
NEO4J_HTTPS_PORT=7483

# =============================================================================
# MemMachine Application Configuration
# =============================================================================
MEMORY_CONFIG=configuration.yml
MCP_BASE_URL=http://memmachine:8880
GATEWAY_URL=http://localhost:8880
FAST_MCP_LOG_LEVEL=INFO

# =============================================================================
# OpenAI API Configuration (Required for embeddings and LLM)
# =============================================================================
OPENAI_API_KEY=gpustack_bae0ff7c11bc5e9b_0c1b0318cbf420b3c9e039c1516805e5

# =============================================================================
# Optional: Additional Configuration
# =============================================================================
# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# MemMachine server port
MEMORY_SERVER_PORT=8880

# Database connection pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# --- Startup model auto-deploy (GPUStack) ---
STARTUP_MODEL_DEPLOY_ENABLED=1
FAIL_ON_STARTUP_MODEL_DEPLOY=0
GPUSTACK_WATCH_TIMEOUT_SECONDS=600

# Choose which models to deploy at startup (name + version must match Model System list)
INIT_EMBEDDING_MODEL=Qwen3-Embedding-0.6B
INIT_EMBEDDING_MODEL_VERSION=1.0.0
INIT_LLM_MODEL=Qwen3-4B
INIT_LLM_MODEL_VERSION=1.0.1

# Model System registry
MODEL_SYSTEM_BASE_URL=http://higress-ai:8080/api/v1
MODEL_SYSTEM_LIST=/models
MODEL_SYSTEM_DOWNLOAD=/models/{id}/download

