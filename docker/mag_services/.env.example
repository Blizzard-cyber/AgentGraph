# MongoDB configuration
MONGO_ROOT_USERNAME=
MONGO_ROOT_PASSWORD=
MONGO_DATABASE=mcp-agent-graph
MONGO_PORT=

# MongoDB Express configuration
MONGO_EXPRESS_PORT=
MONGO_EXPRESS_USERNAME=
MONGO_EXPRESS_PASSWORD=

# MinIO configuration
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_API_PORT=
MINIO_CONSOLE_PORT=
MINIO_SECURE=false

# JWT configuration
# JWT_SECRET_KEY：python mag/scripts/generate_jwt_secret.py
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256

# JWT_ACCESS_TOKEN_EXPIRE_MINUTES: Access Token expiration time (minutes)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=
# JWT_REFRESH_TOKEN_EXPIRE_DAYS: Refresh Token expiration time (days)
JWT_REFRESH_TOKEN_EXPIRE_DAYS=

# Super Admin configuration
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ==================== 云端设备认证配置 ====================
# 云端认证服务地址（用于设备自助注册和认证）
CLOUD_GATEWAY_BASE_UR=http://auth-service:4000

# 本地设备标识符（可选，如果未设置则自动从网卡MAC地址获取）
DEVICE_IDENTIFIER=

# 本地设备ID（可选，用于恢复现有凭证）
DEVICE_ID=

# 本地设备密钥（可选，用于恢复现有凭证）
DEVICE_SECRET=